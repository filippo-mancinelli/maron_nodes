# Demo/Mock Mode — when true (default), the dashboard runs fully populated
# with mock deployment + node data and skips the live WebSocket connection.
# Set to "false" once the Spring API + WS endpoint are reachable.
NEXT_PUBLIC_DEMO_MODE=true

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# NextAuth Configuration
NEXTAUTH_URL=https://app.maronnodes.xyz
NEXTAUTH_SECRET=changeme

# Stripe Configuration (Test Mode)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Feature Flags (optional)
NEXT_PUBLIC_ENABLE_SIGNUP=true
NEXT_PUBLIC_ENABLE_STRIPE=false
