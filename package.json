{
  "name": "maron-nodes-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Maron Nodes - Blockchain Node-as-a-Service Platform",
  "keywords": [
    "blockchain",
    "nodes",
    "saas",
    "infrastructure",
    "web3"
  ],
  "author": "Maron Nodes Team",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "dev:api": "cd apps/api && mvn spring-boot:run",
    "build": "turbo run build",
    "build:web": "pnpm --filter web build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css,scss}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,css,scss}\"",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "setup": "pnpm install && pnpm build",
    "docker:up": "cd apps/api && docker-compose up -d",
    "docker:down": "cd apps/api && docker-compose down"
  },
  "devDependencies": {
    "@turbo/gen": "^2.3.3",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
